---
import type { GithubSnapshot } from "../lib/feed";

interface Props {
  snapshot: GithubSnapshot;
}

const { snapshot } = Astro.props;

// 1234 → "1,2 tis." (Czech compact); small numbers stay as-is.
function compact(n: number): string {
  if (n >= 1000) return `${(n / 1000).toFixed(1).replace(".", ",").replace(",0", "")} tis.`;
  return String(n);
}

function pct(rate: number): string {
  const p = rate * 100;
  return p >= 100 ? `+${Math.round(p)} %` : `+${p.toFixed(0)} %`;
}
---

<section class="gh">
  <ol class="repos">
    {snapshot.repos.map((r) => (
      <li>
        <div class="repo-head">
          <a class="repo-name" href={r.url} target="_blank" rel="noopener noreferrer">{r.repo}</a>
          <span class="growth" title={`${pct(r.growth_rate)} za ${snapshot.window_days} dní`}>
            +{compact(r.stars_gained)} ★
          </span>
        </div>
        {r.description && <p class="repo-desc">{r.description}</p>}
        <div class="repo-stats">
          <span title="Celkem hvězd">★ {compact(r.stars)} celkem</span>
          <span title="Růst za okno">{pct(r.growth_rate)}</span>
          {r.language && <span class="lang">{r.language}</span>}
        </div>
      </li>
    ))}
  </ol>
</section>
