---
import { site } from "../lib/site";

interface Props {
  title?: string;
  description?: string;
  /** Override canonical path; defaults to current pathname. */
  canonicalPath?: string;
  /** Optional JSON-LD object injected into <head>. */
  jsonLd?: Record<string, unknown>;
}

const {
  title,
  description = site.description,
  canonicalPath,
  jsonLd,
} = Astro.props;

const pageTitle = title ? `${title} — ${site.title}` : `${site.title} — ${site.tagline}`;
const canonical = new URL(canonicalPath ?? Astro.url.pathname, Astro.site).href;
const rssUrl = new URL("rss.xml", Astro.site).href;

// Active tab: anything under /trending is the projects section; everything
// else (/, /2, …) is the news section.
const isTrending = Astro.url.pathname.startsWith("/trending");
---

<!doctype html>
<html lang={site.lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.title} />
    <meta property="og:locale" content={site.locale} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />

    <link rel="alternate" type="application/rss+xml" title={site.title} href={rssUrl} />
    <link rel="sitemap" href="/sitemap-index.xml" />

    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}

    <style is:global>
      :root {
        --bg: #ffffff;
        --fg: #16181d;
        --muted: #6b7280;
        --rule: #e6e8eb;
        --link: #1f6feb;
        --max: 680px;
      }
      @media (prefers-color-scheme: dark) {
        :root {
          --bg: #0f1115;
          --fg: #e6e8eb;
          --muted: #8b93a1;
          --rule: #232733;
          --link: #6fb0ff;
        }
      }
      * { box-sizing: border-box; }
      html { -webkit-text-size-adjust: 100%; }
      body {
        margin: 0;
        background: var(--bg);
        color: var(--fg);
        font: 16px/1.6 -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
      }
      .wrap { max-width: var(--max); margin: 0 auto; padding: 48px 20px 96px; }
      a { color: var(--link); }
      header.site { margin-bottom: 8px; }
      h1.titles {
        font-size: 1.5rem; margin: 0 0 6px; letter-spacing: -0.01em;
        font-weight: 700; display: flex; flex-wrap: wrap; gap: 4px 18px;
      }
      h1.titles a { color: var(--muted); text-decoration: none; }
      h1.titles a:hover { color: var(--fg); }
      h1.titles a.active { color: var(--fg); }
      .sub { color: var(--muted); font-size: 0.9rem; margin: 0; }
      .day { margin-top: 40px; }
      .day h2 {
        font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.06em;
        color: var(--muted); font-weight: 600; margin: 0 0 12px;
        padding-bottom: 8px; border-bottom: 1px solid var(--rule);
      }
      .day h2 a { color: inherit; text-decoration: none; }
      .day h2 a:hover { color: var(--link); }
      ul.items { list-style: none; margin: 0; padding: 0; }
      ul.items li { padding: 8px 0; display: flex; gap: 10px; align-items: baseline; }
      ul.items li::before { content: "•"; color: var(--muted); flex: none; }
      .item-body { min-width: 0; }
      a.title { color: var(--fg); text-decoration: none; }
      a.title:hover { color: var(--link); text-decoration: underline; }
      .source { color: var(--muted); font-size: 0.82rem; margin-left: 6px; }
      .group { margin-top: 20px; }
      .group:first-of-type { margin-top: 0; }
      .group-label {
        font-size: 0.8rem; font-weight: 600; color: var(--fg);
        margin: 0 0 4px; letter-spacing: -0.01em;
      }

      /* GitHub trending block */
      .gh { margin-top: 40px; }
      .gh > h2 {
        font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.06em;
        color: var(--muted); font-weight: 600; margin: 0 0 16px;
        padding-bottom: 8px; border-bottom: 1px solid var(--rule);
        display: flex; flex-wrap: wrap; gap: 4px 10px; align-items: baseline;
      }
      .gh-meta { text-transform: none; letter-spacing: 0; font-weight: 400; font-size: 0.78rem; }
      ol.repos { list-style: none; margin: 0; padding: 0; counter-reset: repo; }
      ol.repos li {
        padding: 14px 0; border-bottom: 1px solid var(--rule);
        counter-increment: repo; position: relative; padding-left: 30px;
      }
      ol.repos li:last-child { border-bottom: 0; }
      ol.repos li::before {
        content: counter(repo); position: absolute; left: 0; top: 14px;
        color: var(--muted); font-size: 0.82rem; font-variant-numeric: tabular-nums;
      }
      .repo-head { display: flex; gap: 10px; align-items: baseline; justify-content: space-between; }
      a.repo-name { color: var(--fg); text-decoration: none; font-weight: 600; }
      a.repo-name:hover { color: var(--link); text-decoration: underline; }
      .growth { color: #1a7f37; font-weight: 600; font-size: 0.85rem; flex: none; font-variant-numeric: tabular-nums; }
      @media (prefers-color-scheme: dark) { .growth { color: #3fb950; } }
      .repo-desc { margin: 4px 0 6px; font-size: 0.9rem; line-height: 1.45; }
      .repo-stats { display: flex; flex-wrap: wrap; gap: 12px; color: var(--muted); font-size: 0.8rem; }
      .repo-stats .lang::before { content: "•"; margin-right: 12px; }

      nav.pager { margin-top: 48px; display: flex; justify-content: space-between; gap: 16px; font-size: 0.9rem; }
      nav.pager .spacer { flex: 1; }
      .empty { color: var(--muted); margin-top: 40px; }
      footer.site { margin-top: 64px; color: var(--muted); font-size: 0.8rem; border-top: 1px solid var(--rule); padding-top: 16px; }
      footer.site a { color: var(--muted); }
    </style>
  </head>
  <body>
    <div class="wrap">
      <header class="site">
        <h1 class="titles">
          <a href="/" class={isTrending ? "" : "active"}>novinky</a>
          <a href="/trending" class={isTrending ? "active" : ""}>trending projekty</a>
        </h1>
        <p class="sub"><slot name="sub">{site.tagline}</slot></p>
      </header>
      <main>
        <slot />
      </main>
      <footer class="site">
        Aktualizováno každé ráno · <a href="/rss.xml">RSS</a>
      </footer>
    </div>
  </body>
</html>
