---
import type { GetStaticPaths } from "astro";
import Base from "../../layouts/Base.astro";
import DayBlock from "../../components/DayBlock.astro";
import { days, formatDateLongCs, formatDateCs } from "../../lib/feed";
import { site } from "../../lib/site";
import type { Day } from "../../lib/feed";

export const getStaticPaths = (() => {
  return days.map((day) => ({
    params: { date: day.date },
    props: { day },
  }));
}) satisfies GetStaticPaths;

interface Props {
  day: Day;
}
const { day } = Astro.props;

const title = `Novinky ${formatDateCs(day.date)}`;
const description = `Novinky ze světa umělé inteligence z ${formatDateCs(day.date)}: ${day.items
  .map((it) => it.title)
  .join("; ")}`.slice(0, 300);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: title,
  itemListElement: day.items.map((it, i) => ({
    "@type": "ListItem",
    position: i + 1,
    url: it.url,
    name: it.title,
  })),
};
---

<Base title={title} description={description} jsonLd={jsonLd}>
  <span slot="sub">{formatDateLongCs(day.date)}</span>
  <DayBlock day={day} linkDate={false} />
  <nav class="pager">
    <a href="/">← Zpět na přehled</a>
  </nav>
</Base>
